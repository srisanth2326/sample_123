datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  profile      Profile?
  activities   Activity[]
  goals        Goal[]
  streaks      Streak?
}

model Profile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  onboardingCompleted  Boolean  @default(false)
  
  // Transport answers
  carType              String   @default("none") // none, petrol, diesel, hybrid, ev
  carKmPerWeek        Float    @default(0)
  publicTransitKmWeek  Float    @default(0)
  shortFlightsPerYear  Int      @default(0)
  longFlightsPerYear   Int      @default(0)
  
  // Home energy
  homeSize             Float    @default(0)
  heatingSource        String   @default("electricity") // electricity, gas, oil, renewable
  renewableTariff      Boolean  @default(false)
  
  // Diet
  dietType             String   @default("mixed") // vegan, vegetarian, low-meat, mixed, high-meat
  
  // Consumption & Goods
  shoppingFrequency    String   @default("moderate") // low, moderate, high
  recyclingHabits      String   @default("some") // none, some, all
  
  // Baseline footprint numbers (in kg CO2e / year)
  baselineTransport    Float    @default(0)
  baselineHome         Float    @default(0)
  baselineFood         Float    @default(0)
  baselineGoods        Float    @default(0)
  baselineTotal        Float    @default(0)
  
  updatedAt            DateTime @updatedAt
}

model Activity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionId    String
  category    String
  title       String
  description String
  co2Saved    Float
  timestamp   DateTime @default(now())
}

model Goal {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetReductionPct Float
  targetCo2         Float
  startDate         DateTime @default(now())
  endDate           DateTime
  isActive          Boolean  @default(true)
}

model Streak {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak  Int      @default(0)
  maxStreak      Int      @default(0)
  lastLoggedDate DateTime?
}
